<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Donaciones · Reporte público</title>
<style>
  :root{
    --bg:#0b132b; --card:#1c2541; --accent:#5bc0be; --line:#3a506b;
    --text:#e8eef2; --muted:#9fb3c8;
  }
  *{box-sizing:border-box}
  body{margin:0;font-family:-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;
       background:var(--bg);color:var(--text);padding:18px}
  h1{font-size:22px;margin:0 0 2px}
  .sub{color:var(--muted);font-size:13px;margin-bottom:18px}
  .total-usd:empty{display:none}
  .total-usd{background:linear-gradient(135deg,#13314a,#1c2541);border:1px solid var(--accent);
    border-radius:14px;padding:18px 20px;margin-bottom:16px}
  .total-usd .tu-label{color:var(--muted);font-size:13px;letter-spacing:.5px;text-transform:uppercase}
  .total-usd .tu-monto{color:var(--accent);font-size:34px;font-weight:800;margin-top:2px}
  .total-usd .tu-nota{color:var(--muted);font-size:12px;margin-top:6px}
  .egresos-card{background:linear-gradient(135deg,#3a2230,#2a1c25);border-color:#c97a8a}
  .egresos-card .tu-monto{color:#f0a6b4;font-size:26px}
  .egresos-sec:empty{display:none}
  .egresos-sec{margin:26px 0 8px}
  .sec-tit{font-size:16px;margin:0 0 8px;color:var(--text)}
  .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:22px}
  .card{background:var(--card);border:1px solid var(--line);border-radius:12px;padding:14px}
  .card .moneda{color:var(--accent);font-weight:700;font-size:13px;letter-spacing:.5px}
  .card .monto{font-size:22px;font-weight:700;margin-top:6px}
  .card .det{color:var(--muted);font-size:12px;margin-top:4px}
  .toolbar{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:12px;align-items:center}
  input,select{background:var(--card);border:1px solid var(--line);color:var(--text);
       padding:9px 12px;border-radius:9px;font-size:14px;outline:none}
  input{flex:1;min-width:180px}
  table{width:100%;border-collapse:collapse;font-size:14px}
  th,td{text-align:left;padding:10px 12px;border-bottom:1px solid var(--line)}
  th{color:var(--muted);font-weight:600;cursor:pointer;user-select:none}
  td.monto{text-align:right;font-variant-numeric:tabular-nums;white-space:nowrap}
  tr:hover td{background:rgba(91,192,190,.06)}
  .tag{font-size:11px;color:var(--accent);border:1px solid var(--line);border-radius:20px;padding:2px 8px}
  .foot{color:var(--muted);font-size:12px;margin-top:14px;text-align:center}
  .site-foot{color:var(--muted);font-size:13px;text-align:center;margin:28px 0 80px;
    padding-top:16px;border-top:1px solid var(--line)}
  .site-foot a{color:var(--accent);text-decoration:none;font-weight:600}
  .site-foot a:hover{text-decoration:underline}
  .loading{color:var(--muted);padding:40px;text-align:center}
  .empty{color:var(--muted);padding:34px 18px;text-align:center;font-size:15px;
    border:1px dashed var(--line);border-radius:12px;background:rgba(58,80,107,.12)}
  @media(max-width:520px){ .card .monto{font-size:18px} td,th{padding:8px} }

  .btn-donar{position:fixed;right:18px;bottom:18px;z-index:30;background:var(--accent);
    color:#06121a;font-weight:800;border:none;border-radius:30px;padding:14px 22px;font-size:16px;
    cursor:pointer;box-shadow:0 8px 24px rgba(0,0,0,.45)}
  .btn-donar:hover{filter:brightness(1.07)}
  .head-donar{background:var(--accent);color:#06121a;font-weight:800;border:none;border-radius:9px;
    padding:9px 16px;font-size:14px;cursor:pointer}
  .overlay{position:fixed;inset:0;background:rgba(2,7,15,.72);display:none;z-index:40;
    align-items:flex-start;justify-content:center;padding:24px;overflow:auto}
  .overlay.open{display:flex}
  .modal{background:var(--card);border:1px solid var(--line);border-radius:16px;max-width:460px;width:100%;
    padding:20px;margin-top:24px}
  .modal h2{margin:0 0 4px;font-size:20px}
  .modal .sub2{color:var(--muted);font-size:13px;margin-bottom:16px}
  .pay{border:1px solid var(--line);border-radius:12px;padding:14px;margin-bottom:12px}
  .pay .nombre{color:var(--accent);font-weight:700;font-size:14px;margin-bottom:8px}
  .field{display:flex;justify-content:space-between;align-items:center;gap:10px;padding:6px 0;
    border-top:1px dashed var(--line)}
  .field:first-of-type{border-top:none}
  .field .k{color:var(--muted);font-size:12px}
  .field .v{font-weight:600;font-size:14px;word-break:break-all;text-align:right;flex:1}
  .copy{background:var(--line);color:var(--text);border:none;border-radius:7px;padding:5px 10px;
    font-size:12px;cursor:pointer;white-space:nowrap}
  .copy:hover{background:#46618a}
  .copy.ok{background:var(--accent);color:#06121a}
  .note{color:var(--muted);font-size:13px;padding:4px 0}
  .modal .top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px}
  .x{background:none;border:none;color:var(--muted);font-size:24px;cursor:pointer;line-height:1}
</style>
</head>
<body>

  <!-- ================================================================= -->
  <!--  URL de tu Apps Script (la que termina en /exec) — YA PEGADA       -->
  <!-- ================================================================= -->
  <script>
    const API_URL = "https://script.google.com/macros/s/AKfycbyKLVJVc4mT39F_xOuCSrjFfnIICHVYNQHpMTMlk9HxT8yg6KwwB6WLInSqY_QMsZg/exec";
  </script>

  <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap">
    <div>
      <h1>Reporte de donaciones</h1>
      <div class="sub" id="sub">Cargando datos en vivo…</div>
    </div>
    <button class="head-donar" onclick="abrirDonar()">💚 Donar</button>
  </div>

  <div id="totalUsd" class="total-usd"></div>
  <div id="totalEgresos" class="total-usd egresos-card"></div>

  <div class="cards" id="cards"></div>

  <div class="toolbar">
    <input id="q" placeholder="🔎 Buscar por nombre de donante…" oninput="render()">
    <select id="fMod" onchange="render()"><option value="">Todas las modalidades</option></select>
    <select id="fMon" onchange="render()"><option value="">Todas las monedas</option></select>
  </div>

  <div id="tablaWrap"><div class="loading">Cargando…</div></div>
  <div class="foot" id="foot"></div>

  <div id="egresosList" class="egresos-sec"></div>

  <footer class="site-foot">
    Sistema creado por
    <a href="https://www.instagram.com/isiselinor/" target="_blank" rel="noopener">Isis Elinor</a>
  </footer>

  <button class="btn-donar" onclick="abrirDonar()">💚 Donar</button>

  <div class="overlay" id="overlay" onclick="if(event.target===this)cerrarDonar()">
    <div class="modal">
      <div class="top">
        <div>
          <h2>Quiero donar 💚</h2>
          <div class="sub2">Elige un método y copia los datos. ¡Gracias!</div>
        </div>
        <button class="x" onclick="cerrarDonar()">&times;</button>
      </div>

      <div class="pay">
        <div class="nombre">📱 Pago móvil — Banco de Venezuela</div>
        <div class="field"><span class="k">Cédula</span><span class="v">20227615</span><button class="copy" onclick="copiar(this,'20227615')">Copiar</button></div>
        <div class="field"><span class="k">Teléfono</span><span class="v">0412 230 0869</span><button class="copy" onclick="copiar(this,'04122300869')">Copiar</button></div>
        <div class="field"><span class="k">Banco</span><span class="v">Banco de Venezuela</span><button class="copy" onclick="copiar(this,'Banco de Venezuela')">Copiar</button></div>
      </div>

      <div class="pay">
        <div class="nombre">🟡 Binance</div>
        <div class="field"><span class="k">Correo</span><span class="v">dgorosell@gmail.com</span><button class="copy" onclick="copiar(this,'dgorosell@gmail.com')">Copiar</button></div>
      </div>

      <div class="pay">
        <div class="nombre">🇺🇸 Zelle</div>
        <div class="field"><span class="k">Correo</span><span class="v">maria.leonor.cordero@gmail.com</span><button class="copy" onclick="copiar(this,'maria.leonor.cordero@gmail.com')">Copiar</button></div>
      </div>

      <div class="pay">
        <div class="nombre">💶 Bizum</div>
        <div class="field"><span class="k">Teléfono</span><span class="v">+34 692 529 351</span><button class="copy" onclick="copiar(this,'+34692529351')">Copiar</button></div>
      </div>

      <div class="pay">
        <div class="nombre">🅿️ PayPal</div>
        <div class="field"><span class="k">Correo</span><span class="v">plan.yoga.madrid@gmail.com</span><button class="copy" onclick="copiar(this,'plan.yoga.madrid@gmail.com')">Copiar</button></div>
      </div>

      <div class="pay">
        <div class="nombre">🇦🇷 Pesos argentinos — Lemon</div>
        <div class="field"><span class="k">Alias</span><span class="v">Eidos.lemon</span><button class="copy" onclick="copiar(this,'Eidos.lemon')">Copiar</button></div>
      </div>

      <div class="pay">
        <div class="nombre">💳 Tarjeta de crédito</div>
        <div class="note">Escríbeme por DM y te paso el link de Stripe.</div>
      </div>
    </div>
  </div>

<script>
  var DATA = null;
  var sortCol = 'donante', sortDir = 1;

  function fmt(n, moneda){
    return new Intl.NumberFormat('es-AR',{minimumFractionDigits:2, maximumFractionDigits:2}).format(n);
  }

  function init(d){
    DATA = d;
    document.getElementById('sub').textContent =
      d.totalDonaciones + ' donaciones · actualizado ' + d.actualizado;

    var cards = d.porMoneda.map(function(m){
      var equiv = (m.usd != null)
        ? '<div class="det">≈ US$ '+fmt(m.usd)+'</div>' : '';
      return '<div class="card"><div class="moneda">'+m.simbolo+' · '+m.moneda+'</div>'+
             '<div class="monto">'+fmt(m.total)+'</div>'+
             '<div class="det">'+m.count+' donaciones</div>'+equiv+'</div>';
    }).join('');
    document.getElementById('cards').innerHTML = cards;

    // Tarjeta destacada: total estimado en USD
    if (d.totalUSD != null) {
      document.getElementById('totalUsd').innerHTML =
        '<div class="tu-label">Total recaudado estimado</div>'+
        '<div class="tu-monto">≈ US$ '+fmt(d.totalUSD)+'</div>'+
        '<div class="tu-nota">Conversión estimada · ARS '+fmt(d.tasas.arsPorUsd)+
        '/USD · Bs '+fmt(d.tasas.bsPorUsd)+'/USD · EUR×'+d.tasas.usdPorEur+
        ' · USD y USDT 1:1</div>';
    }

    // Tarjeta de egresos + lista detallada
    if (d.totalEgresos != null && d.totalEgresos > 0) {
      document.getElementById('totalEgresos').innerHTML =
        '<div class="tu-label">Total egresos</div>'+
        '<div class="tu-monto">≈ US$ '+fmt(d.totalEgresos)+'</div>';

      var filas = (d.egresos || []).map(function(e){
        return '<tr><td>'+escapeHtml(e.concepto)+'</td>'+
               '<td class="monto">US$ '+fmt(e.monto)+'</td></tr>';
      }).join('');
      if (filas) {
        document.getElementById('egresosList').innerHTML =
          '<h2 class="sec-tit">Egresos</h2>'+
          '<table><thead><tr><th>Concepto</th><th style="text-align:right">Monto</th></tr></thead>'+
          '<tbody>'+filas+'</tbody></table>';
      }
    }

    var fMod = document.getElementById('fMod');
    d.porModalidad.forEach(function(m){
      var o=document.createElement('option'); o.value=m.modalidad; o.textContent=m.modalidad; fMod.appendChild(o);
    });
    var fMon = document.getElementById('fMon');
    d.porMoneda.forEach(function(m){
      var o=document.createElement('option'); o.value=m.moneda; o.textContent=m.simbolo+' ('+m.moneda+')'; fMon.appendChild(o);
    });

    render();
  }

  function render(){
    if(!DATA) return;
    var q = document.getElementById('q').value.trim().toLowerCase();
    var fmod = document.getElementById('fMod').value;
    var fmon = document.getElementById('fMon').value;

    // Minimalista: la lista se oculta hasta que se busca un nombre
    if(q === ''){
      document.getElementById('tablaWrap').innerHTML =
        '<div class="empty">🔎 Escribe un nombre en la barra de búsqueda para ver las donaciones de esa persona.</div>';
      document.getElementById('foot').textContent = '';
      return;
    }

    var rows = DATA.movimientos.filter(function(m){
      if(q && m.donante.toLowerCase().indexOf(q)===-1) return false;
      if(fmod && m.modalidad!==fmod) return false;
      if(fmon && m.moneda!==fmon) return false;
      return true;
    });

    if(rows.length === 0){
      document.getElementById('tablaWrap').innerHTML =
        '<div class="empty">No encontramos donaciones con ese nombre. Revisa cómo está escrito.</div>';
      document.getElementById('foot').textContent = '';
      return;
    }

    rows.sort(function(a,b){
      var x=a[sortCol], y=b[sortCol];
      if(sortCol==='monto'){ return (x-y)*sortDir; }
      x=String(x).toLowerCase(); y=String(y).toLowerCase();
      return (x<y?-1:x>y?1:0)*sortDir;
    });

    var html = '<table><thead><tr>'+
      '<th onclick="sortBy(\'donante\')">Donante</th>'+
      '<th onclick="sortBy(\'modalidad\')">Modalidad</th>'+
      '<th onclick="sortBy(\'monto\')" style="text-align:right">Monto</th>'+
      '</tr></thead><tbody>';
    rows.forEach(function(m){
      html += '<tr><td>'+escapeHtml(m.donante)+'</td>'+
              '<td><span class="tag">'+m.modalidad+'</span></td>'+
              '<td class="monto">'+m.simbolo+' '+fmt(m.monto,m.moneda)+'</td></tr>';
    });
    html += '</tbody></table>';
    document.getElementById('tablaWrap').innerHTML = html;
    document.getElementById('foot').textContent = rows.length + ' resultado(s) mostrados';
  }

  function sortBy(col){
    if(sortCol===col) sortDir*=-1; else { sortCol=col; sortDir=1; }
    render();
  }

  function escapeHtml(s){
    return String(s).replace(/[&<>"']/g,function(c){
      return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
    });
  }

  function fallar(e){
    document.getElementById('tablaWrap').innerHTML =
      '<div class="empty">No se pudieron cargar los datos. Verifica que API_URL esté bien pegada y que la app esté publicada para "Cualquier persona".</div>';
    document.getElementById('sub').textContent = 'Error de conexión';
  }

  // ---- Modal donar ----
  function abrirDonar(){ document.getElementById('overlay').classList.add('open'); }
  function cerrarDonar(){ document.getElementById('overlay').classList.remove('open'); }
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') cerrarDonar(); });

  function copiar(btn, texto){
    var done = function(){
      var t = btn.textContent; btn.textContent='✓ Copiado'; btn.classList.add('ok');
      setTimeout(function(){ btn.textContent=t; btn.classList.remove('ok'); }, 1400);
    };
    if(navigator.clipboard && navigator.clipboard.writeText){
      navigator.clipboard.writeText(texto).then(done, function(){ fallback(texto); done(); });
    } else { fallback(texto); done(); }
  }
  function fallback(texto){
    var ta=document.createElement('textarea'); ta.value=texto;
    ta.style.position='fixed'; ta.style.opacity='0'; document.body.appendChild(ta);
    ta.select(); try{ document.execCommand('copy'); }catch(e){} document.body.removeChild(ta);
  }

  // ---- Cargar datos desde el Apps Script vía JSONP (evita el bloqueo CORS) ----
  var _cargado = false;
  window.__recibeDonaciones = function(d){ _cargado = true; init(d); };

  function cargarDatos(){
    var sep = API_URL.indexOf('?') === -1 ? '?' : '&';
    var s = document.createElement('script');
    s.src = API_URL + sep + 'callback=__recibeDonaciones';
    s.onerror = function(){ fallar(); };
    document.body.appendChild(s);
    setTimeout(function(){ if(!_cargado) fallar(); }, 12000);
  }
  cargarDatos();
</script>
</body>
</html>
